# Webhook URL for daily push notification.
# Leave empty to skip notifications (digest still saved to digests/).
#
# --- WeChat Work group robot (企业微信群机器人) ---
# Group settings -> Group bot -> Add bot, copy the webhook URL.
# Looks like: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
#
# --- DingTalk group robot (钉钉自定义机器人) ---
# Group settings -> Smart assistant -> Add bot -> Custom, copy the webhook URL.
# Looks like: https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# Safety setting: pick "custom keyword" and use "新闻" (matches digest title).
#
# In GitHub, set this as a repository secret named WEBHOOK_URL:
#   Settings -> Secrets and variables -> Actions -> New repository secret
WEBHOOK_URL=
